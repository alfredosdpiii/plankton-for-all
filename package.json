{
  "name": "pi-plankton",
  "version": "1.0.0",
  "type": "module",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alfredosdpiii/pi-plankton.git"
  },
  "originalRepository": "https://github.com/alexfazio/plankton",
  "main": ".pi/extensions/plankton/index.ts",
  "files": [
    ".pi/extensions/plankton",
    "README.md",
    "package.json"
  ],
  "pi": {
    "extensions": [".pi/extensions/plankton"],
    "image": "https://raw.githubusercontent.com/alfredosdpiii/pi-plankton/main/assets/plankton-cover.png"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@mariozechner/pi-ai": "^0.69.0",
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "@mariozechner/pi-tui": "^0.69.0",
    "oxlint": "^1.49.0",
    "typebox": "^1.1.32",
    "typescript": "^5.9.3"
  },
  "bugs": {
    "url": "https://github.com/alfredosdpiii/pi-plankton/issues"
  },
  "description": "A fork of alexfazio/plankton that provides a Pi-exclusive extension for root-aware code quality enforcement.",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "homepage": "https://github.com/alfredosdpiii/pi-plankton#readme",
  "keywords": [
    "pi-package",
    "pi",
    "plankton",
    "fork",
    "linting"
  ],
  "license": "ISC",
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bunx tsc --noEmit && bash .plankton/test/test_auto_init.sh && bash .plankton/test/test_hook.sh --self-test && uv run pytest",
    "pack:dry-run": "npm pack --dry-run"
  }
}
